{
  "AgentRuntime": {
    "PublicUrl": "http://127.0.0.1:46321",
    "Origins": {
      "Interactive": [
        "https://kuberkynesis.com",
        "https://kuberkynesis.pages.dev",
        "https://app.kuberkynesis.com",
        "http://localhost:5173",
        "https://localhost:5173"
      ],
      "PreviewPattern": "^https://[a-z0-9-]+\\.kuberkynesis\\.pages\\.dev$"
    },
    "Pairing": {
      "CodeLength": 6,
      "NonceLifetimeSeconds": 60,
      "PairingCodeRotationMinutes": 10,
      "SessionLifetimeHours": 8,
      "MaxInteractiveSessions": 1,
      "WebSocketTicketLifetimeSeconds": 60,
      "DisconnectReleaseGraceSeconds": 5
    },
    "PreviewReadOnlyLimits": {
      "MaxConcurrentStreams": 8,
      "MaxWatchCountPerSession": 12,
      "MaxLogStreamsPerSession": 4
    },
    "Metrics": {
      "SourceMode": "MetricsApiPreferred",
      "Prometheus": {
        "Enabled": false,
        "BaseUrl": "",
        "TimeoutSeconds": 5,
        "CpuRateWindow": "5m"
      }
    },
    "UiLaunch": {
      "AutoOpenBrowser": true,
      "AutoConnectWithPairingCode": true,
      "Url": "https://kuberkynesis.com/",
      "ReadyTimeoutSeconds": 25
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
